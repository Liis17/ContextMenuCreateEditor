<ui:FluentWindow
    x:Class="ContextMenuCreateEditor.WPF.Views.ConflictDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Конфликт расширения"
    Width="560"
    Height="320"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Конфликт расширения" />

        <StackPanel Grid.Row="1" Margin="20,12,20,0">
            <TextBlock
                Margin="0,0,0,12"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding HeaderText}"
                TextWrapping="Wrap" />
            <TextBlock
                Foreground="#FFB86A"
                Text="Перезапись ассоциации может сломать открытие файлов этого типа другими приложениями."
                TextWrapping="Wrap" />
            <TextBlock
                Margin="0,12,0,0"
                Foreground="#BBBBBB"
                Text="Выберите, как поступить:"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="20,12,20,16"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Appearance="Primary"
                Click="UseExisting_Click"
                Content="Использовать существующий"
                ToolTip="Сохранить ассоциацию, добавить только пункт «Создать»" />
            <ui:Button
                Margin="0,0,8,0"
                Appearance="Danger"
                Click="ForceRecreate_Click"
                Content="Пересоздать принудительно"
                ToolTip="Перезаписать ProgID — может сломать ассоциацию" />
            <ui:Button Click="Cancel_Click" Content="Отмена" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
