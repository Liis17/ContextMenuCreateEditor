<UserControl
    x:Class="ContextMenuCreateEditor.WPF.UserControls.PreviewItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ContextMenuCreateEditor.WPF.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Margin="4"
    Padding="12,7,12,7"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Border
            Margin="-15,-10,-15,-10"
            Background="#252525"
            CornerRadius="15" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    x:Name="TitleTextBlock"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Foreground="White"
                    Text="Заголовок" />
                <TextBlock
                    x:Name="FormatTextBlock"
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Foreground="White"
                    Text="формат" />
            </Grid>

            <Image x:Name="IconItem" Margin="3" />

        </Grid>



    </Grid>
</UserControl>
