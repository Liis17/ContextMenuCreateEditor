<ui:FluentWindow
    x:Class="ContextMenuCreateEditor.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ContextMenuCreateEditor.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <ui:TitleBar Panel.ZIndex="999" />
        <TextBlock
            Margin="0,3,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Text="Сейчас добавлено" />
        <ScrollViewer
            Margin="10,32,10,50"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <WrapPanel
                x:Name="PreviewPanel"
                HorizontalAlignment="Left"
                Focusable="False"
                Orientation="Horizontal" />
        </ScrollViewer>
        <TextBlock
            x:Name="ListItems"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" />

        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                x:Name="TitleTb"
                Grid.Column="0"
                Margin="5,0,0,2"
                Icon="Pen20"
                IconPlacement="Left"
                PlaceholderText="Отображаемое имя" />
            <ui:TextBox
                x:Name="FormatTb"
                Grid.Column="1"
                Margin="5,0,3,2"
                PlaceholderText="Формат файла" />
            <ui:Button
                Grid.Column="2"
                Margin="2,0,2,2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="Button_Click"
                Content="Добавить" />
            <ui:Button
                Grid.Column="4"
                Margin="2,0,2,2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="ExplorerRestart"
                Content="Перезапустить проводник" />
        </Grid>

    </Grid>

</ui:FluentWindow>
